{
  "name": "minecodes",
  "version": "1.0.0",
  "description": "为Minecraft玩家准备的辅助工具",
  "author": "ZionyasVan",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win"
  },
  "build": {
    "appId": "com.zionyasvan.minecodes",
    "productName": "MineCodes",
    "directories": {
      "output": "dist"
    },
  "win": {
    "target": "portable",
    "forceCodeSigning": false,
    "signAndEditExecutable": false
  }
  },
  "devDependencies": {
    "electron": "^28.0.0"
  },
  "dependencies": {
    "@material/web": "^2.0.0"
  }
}